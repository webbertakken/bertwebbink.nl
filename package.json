{
  "name": "bertwebbink.nl",
  "private": true,
  "workspaces": [
    "visual-migrator"
  ],
  "description": "Bert Webbink's blog",
  "keywords": [
    "Bert",
    "Webbink",
    "Blog",
    "Organs"
  ],
  "scripts": {
    "predev": "yarn extract-types && yarn typegen",
    "dev": "node scripts/ensure-husky.mjs && next dev --turbopack -p 3090",
    "prebuild": "yarn extract-types && yarn typegen",
    "build": "next build",
    "start": "next start -p 3090",
    "lint": "node scripts/lint.mjs",
    "test": "node scripts/ensure-husky.mjs && vitest run",
    "coverage": "vitest --coverage",
    "typegen": "sanity typegen generate",
    "check-types": "tsgo --noEmit",
    "check-types:tsc": "tsc --noEmit",
    "cleanup:pre-i18n": "tsx scripts/cleanup-pre-i18n.ts",
    "migrate:i18n": "tsx scripts/migrate-add-language.ts",
    "translate:ui": "tsx scripts/translate-ui-messages.ts",
    "translate:content": "tsx scripts/translate-content.ts",
    "backup:sanity": "tsx scripts/backup-sanity.ts",
    "extract-types": "sanity schema extract --enforce-required-fields",
    "setup:hooks": "node scripts/ensure-husky.mjs",
    "format": "oxfmt --write",
    "format:check": "oxfmt --check",
    "prepare": "husky"
  },
  "resolutions": {
    "@sanity/client": "^7.22.0"
  },
  "dependencies": {
    "@sanity/client": "^7.22",
    "@sanity/document-internationalization": "^6.1.1",
    "@sanity/icons": "^3.7.4",
    "@sanity/image-url": "^2",
    "@sanity/language-filter": "^5.0.1",
    "@sanity/types": "^5.22",
    "@sanity/uuid": "^3.0.2",
    "@sanity/vision": "^5.22",
    "@tailwindcss/postcss": "^4.1.8",
    "@tailwindcss/typography": "^0.5.16",
    "@vercel/speed-insights": "^1.1.0",
    "autoprefixer": "^10.4.20",
    "date-fns": "^4.1.0",
    "next": "^16.2.4",
    "next-intl": "^4.11.0",
    "next-sanity": "^11.5",
    "pluralize-esm": "^9.0.5",
    "postcss": "^8.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sanity": "^5.22",
    "sanity-plugin-asset-source-unsplash": "^7",
    "sanity-plugin-internationalized-array": "^5.1.1",
    "sanity-plugin-media": "^4",
    "sonner": "^1.7.0",
    "styled-components": "^6.1.13",
    "tailwindcss": "^4.1.8"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5",
    "@types/node": "^20.17.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260425.1",
    "@vitejs/plugin-react": "^4.5.1",
    "@vitest/coverage-v8": "3.2.2",
    "dotenv": "^16.5.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "express": "^5.1.0",
    "husky": "9",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.62.0",
    "typescript": "5.8.3",
    "vite": "^6.3.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.2"
  },
  "packageManager": "yarn@4.14.1",
  "dependenciesMeta": {
    "@parcel/watcher": {
      "built": true
    },
    "@swc/core": {
      "built": true
    },
    "@tailwindcss/oxide": {
      "built": true
    },
    "@vercel/speed-insights": {
      "built": true
    },
    "esbuild": {
      "built": true
    },
    "sharp": {
      "built": true
    }
  },
  "lint-staged": {
    "*.@(ts|tsx|mts|js|jsx|mjs|cjs)": [
      "oxlint --fix --quiet",
      "oxfmt --write"
    ],
    "*.@(json|jsonc|json5|md|mdx|yaml|yml|css|scss|sass|html|toml)": "oxfmt --write",
    ".github/workflows/*.@(yml|yaml)": "actionlint"
  }
}
