NEXT_PUBLIC_SANITY_PROJECT_ID="o98l2fej" # Required - The ID of your Sanity project
NEXT_PUBLIC_SANITY_DATASET="production" # Required - The dataset of your Sanity project
NEXT_PUBLIC_SANITY_API_VERSION="2025-06-08" # Optional - The API version provided to the Sanity Client
NEXT_PUBLIC_SANITY_PREVIEW_URL="http://localhost:3090" # Required - The URL for previewing content (i.e. http://localhost:3090)
NEXT_PUBLIC_SANITY_STUDIO_URL="http://localhost:3090/admin" # Required - The URL for the Sanity Studio (i.e. http://localhost:3090/admin)
SANITY_API_READ_TOKEN="<paste your token here>" # Required - The read token for your Sanity project

# Set to "true" to flip the entire public site to the /under-construction
# page. /admin, /api/*, /_next/* and Sanity draft mode are always allowed.
# Visitors with the secret can bypass: ?bypass=happy birthday (sets a cookie),
# or use the form on /under-construction.
#
# A hardcoded launch timestamp in `core/launch.ts` also keeps the gate active
# until that moment passes, regardless of this var.
UNDER_CONSTRUCTION="false"
